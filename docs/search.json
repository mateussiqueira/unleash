---
layout: null
---
[
  {% assign pages = site.html_pages | where_exp:"p","p.title != null" %}
  {% for page in pages %}
  {
    "title": "{{ page.title | escape }}",
    "url": "{{ page.url | relative_url | replace:'.html','' }}",
    "content": "{{ page.content | strip_html | normalize_whitespace | escape }}"
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
